# ── SMN Configuration ──────────────────────────────────────────────
# Copy to .env and fill in your values.

# Secret key for token signing – CHANGE THIS in production
SMN_SECRET_KEY=change-me-in-production

# Database (SQLite for dev, PostgreSQL for prod)
SMN_DATABASE_URL=sqlite+aiosqlite:///./smn.db
# SMN_DATABASE_URL=postgresql+asyncpg://smn:password@localhost:5432/smn

# Studio workflow database (separate from core SMN data)
SMN_STUDIO_DATABASE_URL=sqlite+aiosqlite:///./studio.db
# SMN_STUDIO_DATABASE_URL=postgresql+asyncpg://smn:password@localhost:5432/smn_studio

# Default LLM model (litellm format: provider/model)
SMN_DEFAULT_MODEL=anthropic/claude-sonnet-4-6-20250415

# Policy directory
SMN_POLICY_DIR=policies

# Governance defaults
SMN_MAX_COST_PER_TASK_USD=5.00
SMN_REQUIRE_HUMAN_APPROVAL_ABOVE_USD=1.00
SMN_AUDIT_RETENTION_DAYS=2555

# Server
SMN_HOST=127.0.0.1
SMN_PORT=8000
SMN_DEBUG=false

# ── Stripe Billing ────────────────────────────────────────────────
# SMN_STRIPE_SECRET_KEY=sk_test_...
# SMN_STRIPE_WEBHOOK_SECRET=whsec_...
# SMN_STRIPE_PRICE_ID_CORE=price_...
# SMN_STRIPE_PRICE_ID_GROWTH=price_...
# SMN_STRIPE_PRICE_ID_USAGE=price_...

# ── Redis (rate limiting + task queue) ────────────────────────────
SMN_REDIS_URL=redis://localhost:6379/0
SMN_TASK_QUEUE_BACKEND=redis://localhost:6379/1

# ── Rate Limiting ─────────────────────────────────────────────────
SMN_RATE_LIMIT_DEFAULT_RPM=60
SMN_RATE_LIMIT_BURST=10

# LLM provider keys (set the ones you use)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AZURE_API_KEY=...
# GOOGLE_APPLICATION_CREDENTIALS=...
